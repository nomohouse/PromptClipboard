<Window x:Class="PromptClipboard.App.Views.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="600" Height="500"
        MinWidth="400" MinHeight="350"
        WindowStartupLocation="CenterScreen"
        Background="#1a1b2e"
        Foreground="#e2e8f0">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Title" Margin="0,0,0,4" FontSize="12" Foreground="#94a3b8"/>
        <TextBox Grid.Row="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                Background="#242540" Foreground="#e2e8f0" BorderBrush="#3d3e6b"
                Padding="8" Margin="0,0,0,12" FontSize="14"/>

        <TextBox Grid.Row="2" Text="{Binding Body, UpdateSourceTrigger=PropertyChanged}"
                Background="#242540" Foreground="#e2e8f0" BorderBrush="#3d3e6b"
                Padding="8" Margin="0,0,0,12" AcceptsReturn="True" AcceptsTab="True"
                TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontSize="13"
                FontFamily="Consolas"/>

        <TextBlock Grid.Row="3" Text="Tags (comma-separated)" Margin="0,0,0,4" FontSize="12" Foreground="#94a3b8"/>
        <TextBox Grid.Row="4" Text="{Binding TagsInput, UpdateSourceTrigger=PropertyChanged}"
                Background="#242540" Foreground="#e2e8f0" BorderBrush="#3d3e6b"
                Padding="8" Margin="0,0,0,12" FontSize="13"/>

        <Grid Grid.Row="5" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Folder" Margin="0,0,0,4" FontSize="12" Foreground="#94a3b8"/>
                <TextBox Text="{Binding Folder, UpdateSourceTrigger=PropertyChanged}"
                        Background="#242540" Foreground="#e2e8f0" BorderBrush="#3d3e6b" Padding="8" FontSize="13"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                <TextBlock Text="Language" Margin="0,0,0,4" FontSize="12" Foreground="#94a3b8"/>
                <TextBox Text="{Binding Lang, UpdateSourceTrigger=PropertyChanged}"
                        Background="#242540" Foreground="#e2e8f0" BorderBrush="#3d3e6b" Padding="8" FontSize="13"/>
            </StackPanel>
            <CheckBox Grid.Column="2" Content="Pinned" IsChecked="{Binding IsPinned}"
                     Foreground="#e2e8f0" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
        </Grid>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Delete" Command="{Binding DeleteCommand}"
                   Background="#dc2626" Foreground="White" BorderThickness="0"
                   Padding="16,8" Margin="0,0,8,0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Cancel" Command="{Binding CancelCommand}"
                   Background="#374151" Foreground="White" BorderThickness="0"
                   Padding="16,8" Margin="0,0,8,0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Save" Command="{Binding SaveCommand}"
                   Background="#6366f1" Foreground="White" BorderThickness="0"
                   Padding="16,8" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
