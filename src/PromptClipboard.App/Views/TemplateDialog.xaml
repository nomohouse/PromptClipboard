<Window x:Class="PromptClipboard.App.Views.TemplateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fill template"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="#1a1b2e"
        Foreground="#e2e8f0">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ItemsControl Grid.Row="0" ItemsSource="{Binding Fields}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Margin="0,0,0,4"
                                  Foreground="#e2e8f0" FontSize="13"/>
                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                Background="#242540" Foreground="#e2e8f0" BorderBrush="#3d3e6b"
                                Padding="8" FontSize="13"
                                AcceptsReturn="True" TextWrapping="Wrap"
                                MinHeight="32" MaxHeight="120"
                                VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Cancel" Command="{Binding CancelCommand}"
                   Background="#374151" Foreground="White" BorderThickness="0"
                   Padding="16,8" Margin="0,0,8,0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Insert" Command="{Binding ConfirmCommand}"
                   Background="#6366f1" Foreground="White" BorderThickness="0"
                   Padding="16,8" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
