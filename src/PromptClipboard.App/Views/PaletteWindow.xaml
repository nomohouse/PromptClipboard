<Window x:Class="PromptClipboard.App.Views.PaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PromptClipboard.App"
        xmlns:vm="clr-namespace:PromptClipboard.App.ViewModels"
        Title="Prompt Clipboard"
        Width="700" Height="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Deactivated="Window_Deactivated"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#1a1b2e"/>
        <SolidColorBrush x:Key="CardBrush" Color="#242540"/>
        <SolidColorBrush x:Key="CardSelectedBrush" Color="#2d2e52"/>
        <SolidColorBrush x:Key="TextBrush" Color="#e2e8f0"/>
        <SolidColorBrush x:Key="TextDimBrush" Color="#94a3b8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#6366f1"/>
        <SolidColorBrush x:Key="AccentBrush2" Color="#8b5cf6"/>
        <SolidColorBrush x:Key="TagBrush" Color="#1e1f3a"/>
        <SolidColorBrush x:Key="BadgeBrush" Color="#6366f1"/>
        <SolidColorBrush x:Key="PinBrush" Color="#fbbf24"/>
    </Window.Resources>

    <Border Background="{StaticResource BgBrush}" CornerRadius="12" BorderThickness="1">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#6366f1" Offset="0"/>
                <GradientStop Color="#8b5cf6" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Drag Header — 40px tall, visually distinct -->
            <Border Grid.Row="0" Background="#161728" CornerRadius="12,12,0,0" Cursor="SizeAll"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Height="40" Margin="16,0,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Drag dots icon -->
                    <TextBlock Grid.Column="0" Text="&#xE700;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                              Foreground="#4a4b6a" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Text="Prompt Clipboard" FontSize="12" FontWeight="SemiBold"
                              Foreground="#6b7280" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                           FontSize="10" Foreground="#6b7280" Background="Transparent"
                           BorderThickness="0" Cursor="Hand" Padding="10,8" Margin="0"
                           ToolTip="Close (Esc)" Click="CloseButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="CloseBorder" Background="Transparent" CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CloseBorder" Property="Background" Value="#3b1219"/>
                                        <Setter Property="Foreground" Value="#fca5a5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Search Bar -->
            <Grid Grid.Row="1" Margin="16,12,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                          Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="16"/>
                <Grid Grid.Column="1">
                    <TextBox x:Name="SearchBox"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                            Background="Transparent" Foreground="{StaticResource TextBrush}"
                            BorderThickness="0" FontSize="14" VerticalAlignment="Center"
                            CaretBrush="{StaticResource AccentBrush}"
                            AutomationProperties.Name="Search prompts"/>
                    <TextBlock Text="Search prompts... (#tag, lang:en)"
                              Foreground="{StaticResource TextDimBrush}" FontSize="14"
                              VerticalAlignment="Center" IsHitTestVisible="False" Margin="2,0,0,0"
                              Visibility="{Binding SearchText, Converter={x:Static local:Converters.StringEmptyToVisibleConverter}}"/>
                </Grid>
                <!-- Clear search button -->
                <Button Grid.Column="2" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                       FontSize="10" Foreground="{StaticResource TextDimBrush}" Background="Transparent"
                       BorderThickness="0" Cursor="Hand" Padding="6,6" Margin="4,0,0,0"
                       Command="{Binding ClearSearchCommand}"
                       Visibility="{Binding SearchText, Converter={x:Static local:Converters.StringNotEmptyToVisibleConverter}}"
                       ToolTip="Clear search" AutomationProperties.Name="Clear search"
                       TabIndex="1">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ClearBorder" Background="Transparent" CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ClearBorder" Property="Background" Value="#2a2b4a"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Grid.Column="3" Content="+ New"
                       Command="{Binding CreateCommand}"
                       Background="{StaticResource AccentBrush}" Foreground="White"
                       BorderThickness="0" Padding="12,6" Margin="8,0,0,0"
                       FontSize="12" Cursor="Hand"
                       AutomationProperties.Name="Create new prompt"
                       TabIndex="2">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Keyboard Hints -->
            <WrapPanel Grid.Row="2" Margin="16,0,16,8">
                <Border Background="{StaticResource CardBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                    <TextBlock Foreground="{StaticResource TextDimBrush}" FontSize="11">
                        <Run FontWeight="Bold" Foreground="{StaticResource TextBrush}">DblClick/Enter</Run>
                        <Run Text=" paste"/>
                    </TextBlock>
                </Border>
                <Border Background="{StaticResource CardBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                    <TextBlock Foreground="{StaticResource TextDimBrush}" FontSize="11">
                        <Run FontWeight="Bold" Foreground="{StaticResource TextBrush}">Ctrl+Enter</Run>
                        <Run Text=" copy text"/>
                    </TextBlock>
                </Border>
                <Border Background="{StaticResource CardBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                    <TextBlock Foreground="{StaticResource TextDimBrush}" FontSize="11">
                        <Run FontWeight="Bold" Foreground="{StaticResource TextBrush}">Ctrl+N</Run>
                        <Run Text=" new"/>
                    </TextBlock>
                </Border>
                <Border Background="{StaticResource CardBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                    <TextBlock Foreground="{StaticResource TextDimBrush}" FontSize="11">
                        <Run FontWeight="Bold" Foreground="{StaticResource TextBrush}">Esc</Run>
                        <Run Text=" clear/close"/>
                    </TextBlock>
                </Border>
                <!-- Syntax help icon -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,6,0"
                       ToolTip="Search syntax:&#x0a;#tag — filter by tag (multi-tag AND)&#x0a;-#tag — exclude tag&#x0a;-word — exclude word&#x0a;lang:en — filter by language&#x0a;folder:work — filter by folder&#x0a;is:pinned / is:template — filter&#x0a;&quot;exact phrase&quot; — quoted phrase&#x0a;Esc — clear search, then close"
                       Cursor="Help">
                    <TextBlock Text="?" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold"/>
                </Border>
            </WrapPanel>

            <!-- Quick Filter Chips + Sort -->
            <Grid Grid.Row="3" Margin="16,0,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ToggleButton Grid.Column="0" Content="Pinned" IsChecked="{Binding IsFilterPinned}"
                             Foreground="{StaticResource TextDimBrush}" Background="{StaticResource CardBrush}"
                             BorderThickness="0" Padding="8,4" Margin="0,0,4,0" Cursor="Hand" FontSize="11"
                             AutomationProperties.Name="Filter pinned" TabIndex="3">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="ChipBorder" Background="{StaticResource CardBrush}" CornerRadius="12"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="ChipBorder" Property="Background" Value="{StaticResource AccentBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ChipBorder" Property="Background" Value="#2a2b4a"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
                <ToggleButton Grid.Column="1" Content="Recent" IsChecked="{Binding IsFilterRecent}"
                             Foreground="{StaticResource TextDimBrush}" Background="{StaticResource CardBrush}"
                             BorderThickness="0" Padding="8,4" Margin="0,0,4,0" Cursor="Hand" FontSize="11"
                             AutomationProperties.Name="Filter recent" TabIndex="4">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="ChipBorder" Background="{StaticResource CardBrush}" CornerRadius="12"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="ChipBorder" Property="Background" Value="{StaticResource AccentBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ChipBorder" Property="Background" Value="#2a2b4a"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
                <ToggleButton Grid.Column="2" Content="Templates" IsChecked="{Binding IsFilterTemplates}"
                             Foreground="{StaticResource TextDimBrush}" Background="{StaticResource CardBrush}"
                             BorderThickness="0" Padding="8,4" Margin="0,0,4,0" Cursor="Hand" FontSize="11"
                             AutomationProperties.Name="Filter templates" TabIndex="5">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="ChipBorder" Background="{StaticResource CardBrush}" CornerRadius="12"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="ChipBorder" Property="Background" Value="{StaticResource AccentBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ChipBorder" Property="Background" Value="#2a2b4a"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
                <ComboBox Grid.Column="4" SelectedItem="{Binding CurrentSortMode}"
                         ItemsSource="{Binding Source={x:Static local:Converters.SortModeValues}}"
                         Background="{StaticResource CardBrush}" Foreground="{StaticResource TextDimBrush}"
                         BorderThickness="0" FontSize="11" Padding="6,4" MinWidth="90"
                         AutomationProperties.Name="Sort order" TabIndex="6"/>
            </Grid>

            <!-- No-Target Hint -->
            <Border Grid.Row="4" Background="#3b1219" CornerRadius="6" Padding="8,4" Margin="16,0,16,8"
                    Visibility="{Binding HasTarget, Converter={x:Static local:Converters.InverseBoolToVisibilityConverter}}">
                <TextBlock Text="No target window - use the copy button"
                          Foreground="#fca5a5" FontSize="12"/>
            </Border>

            <!-- Result count -->
            <TextBlock Grid.Row="5" Text="{Binding ResultCountText}" Foreground="{StaticResource TextDimBrush}"
                      FontSize="11" Margin="16,0,16,4"
                      Visibility="{Binding ResultCountText, Converter={x:Static local:Converters.StringNotEmptyToVisibleConverter}}"
                      AutomationProperties.Name="Result count"/>

            <!-- Empty Database State -->
            <StackPanel Grid.Row="6" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="16,40,16,16"
                       Visibility="{Binding ShowEmptyDatabase, Converter={x:Static local:Converters.BoolToVisibilityConverter}}">
                <TextBlock Text="No prompts yet" Foreground="{StaticResource TextBrush}" FontSize="16" FontWeight="SemiBold"
                          HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Create your first prompt with Ctrl+N" Foreground="{StaticResource TextDimBrush}" FontSize="13"
                          HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <Button Content="+ Create prompt" Command="{Binding CreateCommand}"
                       Background="{StaticResource AccentBrush}" Foreground="White"
                       BorderThickness="0" Padding="16,8" Cursor="Hand" FontSize="13"
                       HorizontalAlignment="Center"
                       AutomationProperties.Name="Create first prompt">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- No Results State -->
            <StackPanel Grid.Row="6" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="16,40,16,16"
                       Visibility="{Binding ShowNoResults, Converter={x:Static local:Converters.BoolToVisibilityConverter}}">
                <TextBlock Text="Nothing found" Foreground="{StaticResource TextBrush}" FontSize="16" FontWeight="SemiBold"
                          HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Try a different search or create a new prompt" Foreground="{StaticResource TextDimBrush}" FontSize="13"
                          HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <Button Content="+ Create from search" Command="{Binding CreateWithTitleCommand}"
                       Background="{StaticResource AccentBrush}" Foreground="White"
                       BorderThickness="0" Padding="16,8" Cursor="Hand" FontSize="13"
                       HorizontalAlignment="Center"
                       AutomationProperties.Name="Create prompt from search text">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- Load Error State -->
            <StackPanel Grid.Row="6" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="16,40,16,16"
                       Visibility="{Binding ShowLoadError, Converter={x:Static local:Converters.BoolToVisibilityConverter}}">
                <TextBlock Text="{Binding TransientLoadError}" Foreground="#fca5a5" FontSize="13"
                          HorizontalAlignment="Center" Margin="0,0,0,12" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Retry" Command="{Binding RetryLoadCommand}"
                           Background="{StaticResource AccentBrush}" Foreground="White"
                           BorderThickness="0" Padding="12,6" Cursor="Hand" FontSize="12" Margin="0,0,8,0"
                           AutomationProperties.Name="Retry loading prompts">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Dismiss" Command="{Binding DismissErrorCommand}"
                           Background="{StaticResource CardBrush}" Foreground="{StaticResource TextDimBrush}"
                           BorderThickness="0" Padding="12,6" Cursor="Hand" FontSize="12"
                           AutomationProperties.Name="Dismiss error">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- CTA Banner: New prompt created -->
            <Border Grid.Row="6" Background="#1e3a5f" CornerRadius="6" Padding="8,6" Margin="16,0,16,8"
                    Visibility="{Binding ShowNewPromptBanner, Converter={x:Static local:Converters.BoolToVisibilityConverter}}"
                    VerticalAlignment="Top" Panel.ZIndex="1">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Show it" Command="{Binding RevealNewPromptCommand}"
                           Background="{StaticResource AccentBrush}" Foreground="White"
                           BorderThickness="0" Padding="10,4" Cursor="Hand" FontSize="11"
                           AutomationProperties.Name="Show new prompt">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock Text="New prompt created" Foreground="#93c5fd" FontSize="12" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- QuickAdd Form (visible when Mode=QuickAdd) -->
            <ScrollViewer Grid.Row="6" Margin="16,0,16,16" VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Mode}" Value="{x:Static vm:PaletteMode.QuickAdd}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel DataContext="{Binding QuickAdd}">
                    <TextBlock Text="Quick Add" Foreground="{StaticResource TextBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <TextBlock Text="Title" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                            Background="{StaticResource CardBrush}" Foreground="{StaticResource TextBrush}"
                            BorderThickness="1" BorderBrush="#3a3b5a" Padding="8,6" FontSize="13"
                            CaretBrush="{StaticResource AccentBrush}"
                            AutomationProperties.Name="Prompt title"/>

                    <TextBlock Text="Body" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,8,0,4"/>
                    <TextBox Text="{Binding Body, UpdateSourceTrigger=PropertyChanged}"
                            Background="{StaticResource CardBrush}" Foreground="{StaticResource TextBrush}"
                            BorderThickness="1" BorderBrush="#3a3b5a" Padding="8,6" FontSize="13"
                            AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80" MaxHeight="160"
                            VerticalScrollBarVisibility="Auto"
                            CaretBrush="{StaticResource AccentBrush}"
                            AutomationProperties.Name="Prompt body"/>

                    <TextBlock Text="Tags (comma separated)" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,8,0,4"/>
                    <TextBox Text="{Binding TagsInput, UpdateSourceTrigger=PropertyChanged}"
                            Background="{StaticResource CardBrush}" Foreground="{StaticResource TextBrush}"
                            BorderThickness="1" BorderBrush="#3a3b5a" Padding="8,6" FontSize="13"
                            CaretBrush="{StaticResource AccentBrush}"
                            AutomationProperties.Name="Tags"/>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Language" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Lang, UpdateSourceTrigger=PropertyChanged}"
                                    Background="{StaticResource CardBrush}" Foreground="{StaticResource TextBrush}"
                                    BorderThickness="1" BorderBrush="#3a3b5a" Padding="8,6" FontSize="13"
                                    CaretBrush="{StaticResource AccentBrush}" Width="120" HorizontalAlignment="Left"
                                    AutomationProperties.Name="Language"/>
                        </StackPanel>
                    </Grid>

                    <!-- Duplicate Warning -->
                    <Border Margin="0,8,0,0" CornerRadius="6" Padding="8,6"
                            Visibility="{Binding DuplicateWarning, Converter={x:Static local:Converters.StringNotEmptyToVisibleConverter}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#3b2e1a"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DuplicateSeverity}" Value="{x:Static vm:DuplicateSeverity.Hard}">
                                        <Setter Property="Background" Value="#3b1219"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding DuplicateWarning}" FontSize="12" Margin="0,0,0,6" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#fbbf24"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DuplicateSeverity}" Value="{x:Static vm:DuplicateSeverity.Hard}">
                                                <Setter Property="Foreground" Value="#fca5a5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Save anyway" Command="{Binding SaveAnywayCommand}"
                                       Foreground="White" BorderThickness="0" Padding="8,4" Cursor="Hand" FontSize="11" Margin="0,0,6,0"
                                       AutomationProperties.Name="Save anyway">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{StaticResource AccentBrush}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="Open existing" Command="{Binding OpenDuplicateCommand}"
                                       Background="{StaticResource CardBrush}" Foreground="{StaticResource TextDimBrush}"
                                       BorderThickness="0" Padding="8,4" Cursor="Hand" FontSize="11" Margin="0,0,6,0"
                                       AutomationProperties.Name="Open existing">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="Cancel" Command="{Binding CancelDuplicateCommand}"
                                       Background="Transparent" Foreground="{StaticResource TextDimBrush}"
                                       BorderThickness="0" Padding="8,4" Cursor="Hand" FontSize="11"
                                       AutomationProperties.Name="Cancel duplicate warning">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Save/Cancel buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Save (Ctrl+Enter)" Command="{Binding SaveCommand}"
                               Background="{StaticResource AccentBrush}" Foreground="White"
                               BorderThickness="0" Padding="12,6" Cursor="Hand" FontSize="12" Margin="0,0,8,0"
                               AutomationProperties.Name="Save prompt">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="Cancel (Esc)"
                               Command="{Binding DataContext.HandleEscapeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                               Background="{StaticResource CardBrush}" Foreground="{StaticResource TextDimBrush}"
                               BorderThickness="0" Padding="12,6" Cursor="Hand" FontSize="12"
                               AutomationProperties.Name="Cancel quick add">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Prompt List (visible when Mode=List) -->
            <ListBox x:Name="PromptListBox" Grid.Row="6" Margin="16,0,16,16"
                     ItemsSource="{Binding Prompts}"
                     SelectedItem="{Binding SelectedPrompt, Mode=TwoWay}"
                     SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     FocusVisualStyle="{x:Null}"
                     HorizontalContentAlignment="Stretch">
                <ListBox.Style>
                    <Style TargetType="ListBox">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Mode}" Value="{x:Static vm:PaletteMode.QuickAdd}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Style>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="{StaticResource CardBrush}"
                                            CornerRadius="8" Padding="12" Cursor="Hand"
                                            BorderThickness="1" BorderBrush="Transparent">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#2a2b4a"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource CardSelectedBrush}"/>
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid MouseLeftButtonUp="Card_MouseLeftButtonUp">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Title Row -->
                            <DockPanel Grid.Row="0">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="&#xE734;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="{Binding Prompt.IsPinned, Converter={x:Static local:Converters.BoolToPinColorConverter}}"
                                           Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4" Margin="2,0"
                                           Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                           CommandParameter="{Binding}"
                                           ToolTip="Pin"/>
                                    <Button Content="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="{StaticResource TextDimBrush}" Background="Transparent"
                                           BorderThickness="0" Cursor="Hand" Padding="4" Margin="2,0"
                                           Tag="{Binding}" Click="EditButton_Click"
                                           ToolTip="Edit"/>
                                    <Button Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="{StaticResource TextDimBrush}" Background="Transparent"
                                           BorderThickness="0" Cursor="Hand" Padding="4" Margin="2,0"
                                           Tag="{Binding}" Click="CopyButton_Click"
                                           ToolTip="Copy"/>
                                    <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="{StaticResource TextDimBrush}" Background="Transparent"
                                           BorderThickness="0" Cursor="Hand" Padding="4" Margin="2,0"
                                           Command="{Binding DataContext.DeletePromptCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                           CommandParameter="{Binding}"
                                           ToolTip="Delete"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Prompt.Title}" Foreground="{StaticResource TextBrush}"
                                              FontWeight="SemiBold" FontSize="14" Margin="0,0,8,0"/>
                                    <Border Background="{StaticResource BadgeBrush}" CornerRadius="4" Padding="6,2"
                                           Visibility="Collapsed" x:Name="TemplateBadge">
                                        <TextBlock Text="Template" Foreground="White" FontSize="10"/>
                                    </Border>
                                </StackPanel>
                            </DockPanel>

                            <!-- Body Preview -->
                            <TextBlock x:Name="BodyPreview" Grid.Row="1" Text="{Binding PreviewText}"
                                      Foreground="{StaticResource TextDimBrush}"
                                      FontSize="12" TextTrimming="CharacterEllipsis" MaxHeight="36"
                                      Margin="0,4,0,0" TextWrapping="Wrap"/>

                            <!-- Meta Label (visible only for long body when collapsed) -->
                            <TextBlock x:Name="MetaLabel" Grid.Row="2" Text="{Binding MetaLabel}"
                                      Foreground="{StaticResource TextDimBrush}" FontSize="11"
                                      FontStyle="Italic" Opacity="0.7"
                                      Margin="0,2,0,0" Visibility="Collapsed"/>

                            <!-- Toggle Button (visible only for long body) -->
                            <Button x:Name="ToggleButton" Grid.Row="3"
                                   Content="{Binding ToggleLabel}"
                                   Command="{Binding ToggleExpandedCommand}"
                                   Visibility="{Binding IsLongBody, Converter={x:Static local:Converters.BoolToVisibilityConverter}}"
                                   Foreground="{StaticResource AccentBrush}" Background="Transparent"
                                   BorderThickness="0" Cursor="Hand" Padding="0,2"
                                   Margin="0,2,0,0" FontSize="11" HorizontalAlignment="Left">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock x:Name="BtnText"
                                                  Text="{TemplateBinding Content}"
                                                  Foreground="{TemplateBinding Foreground}"
                                                  FontSize="{TemplateBinding FontSize}"
                                                  Margin="{TemplateBinding Padding}"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnText" Property="TextDecorations" Value="Underline"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Tags -->
                            <ItemsControl Grid.Row="4"
                                         ItemsSource="{Binding Prompt.TagsJson, Converter={x:Static local:Converters.JsonToTagListConverter}}"
                                         Visibility="{Binding Prompt.TagsJson, Converter={x:Static local:Converters.TagsNotEmptyConverter}}"
                                         Margin="0,4,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource TagBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,4,2">
                                            <TextBlock Foreground="{StaticResource TextDimBrush}" FontSize="11">
                                                <Run Text="#"/><Run Text="{Binding Mode=OneWay}"/>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                        <DataTemplate.Triggers>
                            <!-- Template badge -->
                            <DataTrigger Binding="{Binding Prompt.Body, Converter={x:Static local:Converters.HasTemplateConverter}}" Value="True">
                                <Setter TargetName="TemplateBadge" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <!-- Show meta label when long body AND collapsed -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsLongBody}" Value="True"/>
                                    <Condition Binding="{Binding IsExpanded}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="MetaLabel" Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                            <!-- Expand body preview when expanded -->
                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                <Setter TargetName="BodyPreview" Property="MaxHeight" Value="180"/>
                                <Setter TargetName="BodyPreview" Property="TextTrimming" Value="None"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>
